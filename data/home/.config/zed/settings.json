// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "mouse_wheel_zoom": true,
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "qwen-code": {
      "type": "registry"
    },
    "kimi": {
      "type": "registry"
    },
    "cline": {
      "type": "registry"
    }
  },
  "agent": {
    "default_model": {
      "provider": "openrouter",
      "model": "openrouter/free",
      "enable_thinking": true
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "none"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "preview_tabs": {
    "enable_preview_from_project_panel": true,
  },
  "project_panel": {
    "dock": "left",
    "button": true,
  },
  "debugger": {
    "dock": "left",
  },
  "notification_panel": {
    "dock": "left",
  },
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": false,
    },
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false,
  },
  "tabs": {
    "git_status": false,
    "close_position": "right",
    "show_close_button": "hover",
    "file_icons": true,
    "show_diagnostics": "all",
  },
  "minimap": {
    "thumb": "always",
    "show": "never",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "terminal": {
    "font_size": 14.0,
    "env": {
      "ZED_TERM": "1"
    },
  },
  "lsp": {
    "clangd": {
      "binary": {
        "arguments": ["--header-insertion=never"],
      },
    },
  },
  "remove_trailing_whitespace_on_save": false,
  "format_on_save": "off",
  "auto_indent": "none",
  "ui_font_family": "Fira Code",
  "buffer_font_family": "Fira Code",
  "icon_theme": "JetBrains New UI Icons (Dark)",
  "theme": "GitHub Dark",
  "ui_font_size": 15.0,
  "buffer_font_size": 15,
}
